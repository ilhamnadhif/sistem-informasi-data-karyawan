<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_absensi" pageWidth="595" pageHeight="842" orientation="Portrait"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="11111111-0000-0000-0000-000000000002">
    <parameter name="tgl_mulai" class="java.sql.Date"/>
    <parameter name="tgl_selesai" class="java.sql.Date"/>
    <parameter name="id_karyawan" class="java.lang.Integer"/>
    <queryString>
        <![CDATA[SELECT a.tanggal, k.nik, k.nama, a.jam_masuk, a.jam_keluar, a.status, a.keterangan
                 FROM absensi a
                 JOIN karyawan k ON a.id_karyawan = k.id_karyawan
                 WHERE a.tanggal BETWEEN $P{tgl_mulai} AND $P{tgl_selesai}
                   AND ($P{id_karyawan} IS NULL OR a.id_karyawan = $P{id_karyawan})
                 ORDER BY a.tanggal]]>
    </queryString>
    <field name="tanggal" class="java.sql.Date"/>
    <field name="nik" class="java.lang.String"/>
    <field name="nama" class="java.lang.String"/>
    <field name="jam_masuk" class="java.sql.Time"/>
    <field name="jam_keluar" class="java.sql.Time"/>
    <field name="status" class="java.lang.String"/>
    <field name="keterangan" class="java.lang.String"/>
    <title>
        <band height="40">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[Laporan Absensi]]></text>
            </staticText>
        </band>
    </title>
    <columnHeader>
        <band height="22">
            <staticText><reportElement x="0" y="0" width="70" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Tanggal]]></text></staticText>
            <staticText><reportElement x="70" y="0" width="55" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[NIK]]></text></staticText>
            <staticText><reportElement x="125" y="0" width="110" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Nama]]></text></staticText>
            <staticText><reportElement x="235" y="0" width="55" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Jam Masuk]]></text></staticText>
            <staticText><reportElement x="290" y="0" width="55" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Jam Keluar]]></text></staticText>
            <staticText><reportElement x="345" y="0" width="55" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText>
            <staticText><reportElement x="400" y="0" width="155" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Keterangan]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <textField pattern="dd-MM-yyyy"><reportElement x="0" y="0" width="70" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{tanggal}]]></textFieldExpression></textField>
            <textField><reportElement x="70" y="0" width="55" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{nik}]]></textFieldExpression></textField>
            <textField><reportElement x="125" y="0" width="110" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression></textField>
            <textField pattern="HH:mm"><reportElement x="235" y="0" width="55" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{jam_masuk}]]></textFieldExpression></textField>
            <textField pattern="HH:mm"><reportElement x="290" y="0" width="55" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{jam_keluar}]]></textFieldExpression></textField>
            <textField><reportElement x="345" y="0" width="55" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField>
            <textField><reportElement x="400" y="0" width="155" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textFieldExpression><![CDATA[$F{keterangan}]]></textFieldExpression></textField>
        </band>
    </detail>
    <pageFooter>
        <band height="20">
            <textField><reportElement x="400" y="0" width="155" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
    <summary>
        <band height="120">
            <textField>
                <reportElement x="355" y="15" width="200" height="18"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["Jakarta, " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id","ID")).format(new java.util.Date())]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="355" y="33" width="200" height="18"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Manager,]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="95" width="200" height="18"/>
                <textElement textAlignment="Center"><font isBold="true" isUnderline="true"/></textElement>
                <text><![CDATA[Depi Sipahutar]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
