<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_karyawan" pageWidth="595" pageHeight="842" orientation="Portrait"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="11111111-0000-0000-0000-000000000001">
    <parameter name="id_jabatan" class="java.lang.Integer"/>
    <parameter name="status" class="java.lang.String"/>
    <queryString>
        <![CDATA[SELECT k.nik, k.nama, k.jenis_kelamin, j.nama_jabatan, k.tanggal_masuk, k.status, k.no_telp
                 FROM karyawan k
                 LEFT JOIN jabatan j ON k.id_jabatan = j.id_jabatan
                 WHERE ($P{id_jabatan} IS NULL OR k.id_jabatan = $P{id_jabatan})
                   AND ($P{status} IS NULL OR k.status = $P{status})
                 ORDER BY k.nama]]>
    </queryString>
    <field name="nik" class="java.lang.String"/>
    <field name="nama" class="java.lang.String"/>
    <field name="jenis_kelamin" class="java.lang.String"/>
    <field name="nama_jabatan" class="java.lang.String"/>
    <field name="tanggal_masuk" class="java.sql.Date"/>
    <field name="status" class="java.lang.String"/>
    <field name="no_telp" class="java.lang.String"/>
    <variable name="no" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{nik}]]></variableExpression>
    </variable>
    <title>
        <band height="40">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[Laporan Data Karyawan]]></text>
            </staticText>
        </band>
    </title>
    <columnHeader>
        <band height="22">
            <staticText><reportElement x="0" y="0" width="30" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[No]]></text></staticText>
            <staticText><reportElement x="30" y="0" width="55" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[NIK]]></text></staticText>
            <staticText><reportElement x="85" y="0" width="105" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Nama]]></text></staticText>
            <staticText><reportElement x="190" y="0" width="30" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[JK]]></text></staticText>
            <staticText><reportElement x="220" y="0" width="95" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Jabatan]]></text></staticText>
            <staticText><reportElement x="315" y="0" width="70" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Tgl Masuk]]></text></staticText>
            <staticText><reportElement x="385" y="0" width="60" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText>
            <staticText><reportElement x="445" y="0" width="110" height="22"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center"><font isBold="true"/></textElement><text><![CDATA[No. Telp]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <textField><reportElement x="0" y="0" width="30" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$V{no}]]></textFieldExpression></textField>
            <textField><reportElement x="30" y="0" width="55" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{nik}]]></textFieldExpression></textField>
            <textField><reportElement x="85" y="0" width="105" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression></textField>
            <textField><reportElement x="190" y="0" width="30" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{jenis_kelamin}]]></textFieldExpression></textField>
            <textField><reportElement x="220" y="0" width="95" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textFieldExpression><![CDATA[$F{nama_jabatan}]]></textFieldExpression></textField>
            <textField pattern="dd-MM-yyyy"><reportElement x="315" y="0" width="70" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{tanggal_masuk}]]></textFieldExpression></textField>
            <textField><reportElement x="385" y="0" width="60" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textElement textAlignment="Center"/><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField>
            <textField><reportElement x="445" y="0" width="110" height="20"/><box leftPadding="3" rightPadding="3"><pen lineWidth="0.5"/></box><textFieldExpression><![CDATA[$F{no_telp}]]></textFieldExpression></textField>
        </band>
    </detail>
    <pageFooter>
        <band height="20">
            <textField><reportElement x="400" y="0" width="155" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
    <summary>
        <band height="120">
            <textField>
                <reportElement x="355" y="15" width="200" height="18"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["Jakarta, " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id","ID")).format(new java.util.Date())]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="355" y="33" width="200" height="18"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Manager,]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="95" width="200" height="18"/>
                <textElement textAlignment="Center"><font isBold="true" isUnderline="true"/></textElement>
                <text><![CDATA[Depi Sipahutar]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
